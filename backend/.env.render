# ──────────────────────────────────────────────────────────────────────────────
# Render Free deployment configuration (≤ 512 MB RAM)
# Copy/rename to .env for local testing of render_eval mode.
# ──────────────────────────────────────────────────────────────────────────────

# Deployment mode — disables Ollama, browser agent, Celery, and heavy workers
DEPLOYMENT_MODE=render_eval
APP_ENV=production

# Database — use Render PostgreSQL connection string in production
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./autonomous_builder.db

# Redis — optional; falls back to in-memory cache when unavailable
# REDIS_URL=redis://host:6379/0
REDIS_HEALTHCHECK_ENABLED=false

# AI providers — API-based only (Ollama disabled)
FEATHERLESS_ENABLED=true
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_GENERAL_MODEL=deepseek-ai/DeepSeek-V3-0324
FEATHERLESS_CODING_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct
FEATHERLESS_REASONING_MODEL=deepseek-ai/DeepSeek-V3-0324
FEATHERLESS_MARKETING_MODEL=deepseek-ai/DeepSeek-V3-0324
FEATHERLESS_BROWSER_MODEL=deepseek-ai/DeepSeek-V3-0324
# FEATHERLESS_API_KEY=   # set in Render dashboard
# GROQ_API_KEY=          # set in Render dashboard
# HF_API_KEY=            # set in Render dashboard

# Security
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
SECURE_COOKIES=true

# URLs — update with your Vercel frontend URL
FRONTEND_URL=https://your-app.vercel.app
BACKEND_URL=https://your-backend.onrender.com
CORS_ORIGINS=https://your-app.vercel.app
TRUSTED_HOSTS=localhost,127.0.0.1,*.onrender.com,*.vercel.app

# Feature flags (override defaults from render_eval mode if needed)
ENABLE_OLLAMA=false
ENABLE_BROWSER_AGENT=false
ENABLE_HEAVY_WORKERS=false
ENABLE_API_AI_PROVIDERS=true
