# ═══════════════════════════════════════════════════════════════════════════════
# Autonomous Business Builder — Backend Environment Configuration
# Copy this file to .env and fill in the values you need.
# ═══════════════════════════════════════════════════════════════════════════════

APP_ENV=development
APP_NAME=Autonomous Business Builder
APP_VERSION=0.3.0
TRUSTED_HOSTS=localhost,127.0.0.1,backend,nginx
SECURE_COOKIES=false
METRICS_ENABLED=true
METRICS_PATH=/metrics

# ── Database ──────────────────────────────────────────────────────────────────
# Default: SQLite (works out of the box, no setup needed)
DATABASE_URL=sqlite+aiosqlite:///./autonomous_builder.db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT_SECONDS=30

# For Supabase PostgreSQL (replace <project-ref> and <password>):
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# ── AI Providers (at least one required for business generation) ──────────────
#
# PRIORITY ORDER: Groq → HuggingFace → Ollama
# The system tries each in order and uses the first available.
# If none are configured, /businesses/generate returns 503.
#
# Option 1: Groq (RECOMMENDED — free, fast, no local setup)
#   Get a free key at: https://console.groq.com
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama3-8b-8192

# Option 2: Hugging Face (free, slower — model: Mistral-7B-Instruct-v0.2)
#   Get a free token at: https://huggingface.co/settings/tokens
#   Model docs: https://huggingface.co/mistralai/Mistral-7B-Instruct-v0.2
HF_API_KEY=
HF_BASE_URL=https://api-inference.huggingface.co/models
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.2
# Timeout for HF requests in seconds (model cold-start can take 20-40s)
HF_TIMEOUT_SECONDS=60.0
# How many times to retry when HF says "model is loading"
HF_LOADING_RETRIES=3
# Seconds to wait between loading retries
HF_LOADING_RETRY_DELAY=20.0

# Option 3: Ollama (local, no API key needed, requires Ollama installed)
#   Install: https://ollama.com  |  Then run: ollama pull llama3
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
BROWSER_REASONING_MODEL=llama3
BROWSER_VISION_MODEL=minicpm-v
BROWSER_VISION_MODELS=minicpm-v,llava:13b
BROWSER_VISION_TIMEOUT_SECONDS=5
BROWSER_VISION_FALLBACK_TIMEOUT_SECONDS=8
BROWSER_VISION_KEEP_ALIVE=-1m
BROWSER_VISION_NUM_PREDICT=64
BROWSER_VISION_MAX_IMAGE_WIDTH=960
BROWSER_VISION_MAX_IMAGE_HEIGHT=960
BROWSER_VISION_JPEG_QUALITY=45
BROWSER_PLANNER_TIMEOUT_SECONDS=6
BROWSER_PLANNER_NUM_PREDICT=80
BROWSER_PLANNER_KEEP_ALIVE=-1m
BROWSER_AGENT_MAX_STEPS=12
BROWSER_HEADLESS=false
BROWSER_SESSION_ROOT=./.runtime/browser-sessions

# AI request timeout in seconds
AI_TIMEOUT_SECONDS=25.0

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
# IMPORTANT: Change this in production!
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Payments (optional) ───────────────────────────────────────────────────────
# Get keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# PayPal subscriptions and one-time orders
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox
PAYPAL_WEBHOOK_ID=
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000

# ── URLs ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Redis (optional — enables caching and background jobs) ───────────────────
# Without Redis: caching uses in-memory dict, Celery workers won't start.
# The core API works fine without Redis.
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
REDIS_HEALTHCHECK_ENABLED=true

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=3600

# ── Email (optional) ──────────────────────────────────────────────────────────
# Leave blank to skip email sending (no errors, just silent no-op).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=noreply@autonomousbusiness.ai
EMAIL_FROM_NAME=Autonomous Business Builder

# ── File Uploads (optional) ───────────────────────────────────────────────────
# Leave blank to use local disk storage (uploads/ directory).
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=product-images

# ── Agent System ──────────────────────────────────────────────────────────────
AGENT_LOOP_INTERVAL_SECONDS=3600
AGENT_MAX_ACTIONS_PER_RUN=5

# Platform OAuth
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8000/api/v1/integrations/linkedin/callback
